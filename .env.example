# ── Provider API Keys ──────────────────────────────────────────────────────────
# Set the key(s) for the provider(s) you want to use.
# At least one key is required.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini (direct API — console.cloud.google.com)
GEMINI_API_KEY=your-gemini-api-key-here
# Google Vertex AI (GCP service account) — set path to your credentials JSON instead:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Nebius AI Studio (studio.nebius.ai)
NEBIUS_API_KEY=your-nebius-api-key-here

# ── Model Selection ────────────────────────────────────────────────────────────
# Set CSC_MODEL to any model from any supported provider.
# The prefix determines which provider is used automatically.
#
# Anthropic
#   claude-sonnet-4-20250514
#   claude-opus-4-5
#
# OpenAI
#   gpt-4o
#   gpt-4o-mini
#   o3
#
# Google Gemini (direct API)
#   gemini/gemini-2.0-flash
#   gemini/gemini-1.5-pro
#
# Google Vertex AI
#   vertex_ai/gemini-2.0-flash
#   vertex_ai/gemini-1.5-pro
#
# Nebius AI Studio
#   nebius/Qwen/Qwen3-235B-A22B
#   nebius/meta-llama/Meta-Llama-3.1-70B-Instruct
#   nebius/deepseek-ai/DeepSeek-V3

CSC_MODEL=claude-sonnet-4-20250514

# ── Pipeline Settings ──────────────────────────────────────────────────────────
CSC_MAX_AGENT_TURNS=20
